# ============================================
# Telegram Bot Configuration
# ============================================
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# ============================================
# Multi-AI API Keys (get from respective consoles)
# ============================================

# Groq API - Fast AI Responses
# Get from: https://console.groq.com
GROQ_KEY=gsk-your-groq-key-here

# Tavily Search API - Real-time Web Data
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# NVIDIA API - DeepSeek V3 for Analysis
# Get from: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-nvidia-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-r1
NVIDIA_GEMINI_MODEL=google/gemma-2-27b-it

# Legacy API Keys (optional fallbacks)
GEMINI_KEY=your_gemini_key_here
DEEPSEEK_KEY=your_deepseek_direct_key_here

# ============================================
# Google Apps Script (Cloud Sync)
# ============================================
API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
