# ============================================
# Telegram Bot Configuration
# ============================================
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# ============================================
# 3-Engine FREE AI Architecture
# ============================================

# Groq API - Ultra-Fast AI Responses (FREE)
# Get from: https://console.groq.com
GROQ_KEY=gsk-your-groq-key-here

# Google Gemini API - Real-Time Intelligence (FREE)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude API - Deep Analysis (FREE)
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=your-claude-api-key-here

# Tavily Search API - Real-time Web Data (FREE tier)
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# ============================================
# Google Apps Script (Cloud Sync)
# ============================================
API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
