# ============================================
# Wealth AI Pro Trading Terminal — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# AI PROVIDER KEYS
# --------------------------------------------
# NOTE: AI requests (Groq, Gemini, Claude, OpenRouter, Cerebras, HF,
# NVIDIA) now go through the backend proxy in server/index.js and use
# the SERVER-SIDE keys defined at the bottom of this file. Do NOT put
# AI provider keys in VITE_* vars — that would expose them in the
# browser bundle.
# ============================================

# ============================================
# Tavily Search API (Real-time Web Data) — OPTIONAL
# Used client-side by NeuralChat for live web intel.
# Get your key from: https://tavily.com
# ============================================
VITE_TAVILY_API_KEY=tvly-your-api-key-here

# ============================================
# Telegram Bot Configuration — OPTIONAL (for alerts)
# ============================================
VITE_TG_TOKEN=your_bot_token_here
VITE_TG_CHAT_ID=your_chat_id_here

# Server-side Telegram (used by /api/telegram proxy so the website can send
# notifications even without local browser config). Falls back to VITE_ vars above.
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# ============================================
# Google Apps Script (Cloud Portfolio Sync) — OPTIONAL
# ============================================
VITE_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ============================================
# Security — RECOMMENDED
# ============================================
VITE_SECURE_PIN=2023
VITE_ENCRYPTION_KEY=your-random-encryption-key-here

# ============================================================
# BACKEND PROXY (server/index.js) — SERVER-SIDE KEYS
# ------------------------------------------------------------
# These power /api/ai, /api/groq, /api/gemini, etc. They live
# ONLY on the server and are NEVER exposed to the browser.
# Set them in your host's dashboard (e.g. Render → Environment).
# At least GROQ_API_KEY is recommended so NeuralChat works.
# ============================================================
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
CLAUDE_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
CEREBRAS_API_KEY=your_cerebras_key_here
HF_API_KEY=your_huggingface_key_here
NVIDIA_API_KEY=your_nvidia_key_here
TAVILY_API_KEY=tvly_your_key_here

# If the frontend is hosted on a DIFFERENT origin than this proxy,
# set VITE_API_PROXY at build time to the proxy's base URL, e.g.:
# VITE_API_PROXY=https://wealth-ai-pro.onrender.com

# ------------------------------------------------------------
# REAL-TIME MARKET DATA (price feed)
# ------------------------------------------------------------
# US — true real-time US trades via Finnhub WebSocket (tick-by-tick, no 15-min
# delay). REQUIRED for ultra-fast US prices at market open. Free key at
# https://finnhub.io/register  → Dashboard → API key.
FINNHUB_API_KEY=your_finnhub_key_here
