# ============================================
# Wealth AI Pro — Environment Variables
# ============================================

# SECURITY — REQUIRED (no defaults)
APP_PIN=change_me_to_a_strong_pin
VITE_API_TOKEN=replace_with_strong_12plus_char_secret
VITE_ENCRYPTION_KEY=replace_with_strong_32_char_secret

# CORS allowlist (comma-separated, for cross-origin Vercel→Render)
# If not set, ALL origins are allowed (less secure but works)
ALLOWED_ORIGINS=https://your-app.vercel.app

# AI PROVIDER KEYS (server-side only)
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
CLAUDE_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
CEREBRAS_API_KEY=your_cerebras_key_here
HF_API_KEY=your_huggingface_key_here
NVIDIA_API_KEY=your_nvidia_key_here
TAVILY_API_KEY=tvly_your_key_here

# Telegram Bot (server-side only)
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# Google Apps Script (Cloud Portfolio Sync)
VITE_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# If frontend is on a DIFFERENT origin (Vercel), set this:
# VITE_API_PROXY=https://your-backend.onrender.com

# Real-time market data
FINNHUB_API_KEY=your_finnhub_key_here

# Broker connectors (optional)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
SHOONYA_USER_ID=your_shoonya_user_id
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_API_KEY=your_api_key
SHOONYA_IMEI=100001
