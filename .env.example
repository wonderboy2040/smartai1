# ============================================
# Wealth AI Pro Trading Terminal — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# In production, set these in your host's dashboard (e.g. Render).
# ============================================

# ============================================
# SECURITY — REQUIRED (no defaults, app refuses to start without APP_PIN)
# ============================================

# App access PIN. Verified SERVER-SIDE via /api/auth/login. NEVER exposed
# to the browser. The server refuses to start if this is not set.
APP_PIN=change_me_to_a_strong_pin

# Cloud sync auth token. MUST be a strong secret (>= 12 chars).
# Set the SAME token in server/apps-script/Code.gs (AUTH_TOKEN variable).
# Generate with:  openssl rand -hex 24
VITE_API_TOKEN=replace_with_strong_12plus_char_secret

# Client-side localStorage encryption key (AES-GCM).
# Generate with:  openssl rand -hex 32
VITE_ENCRYPTION_KEY=replace_with_strong_32_char_secret

# ============================================
# AI PROVIDER KEYS (server-side only)
# ============================================
# These power /api/groq, /api/gemini, /api/claude, etc. They live ONLY
# on the server and are NEVER exposed to the browser.
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
CLAUDE_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
CEREBRAS_API_KEY=your_cerebras_key_here
HF_API_KEY=your_huggingface_key_here
NVIDIA_API_KEY=your_nvidia_key_here
TAVILY_API_KEY=tvly_your_key_here

# ============================================
# Telegram Bot Configuration (server-side only)
# ============================================
# Do NOT use VITE_TG_TOKEN / VITE_TG_CHAT_ID — those are browser-exposed.
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# ============================================
# Google Apps Script (Cloud Portfolio Sync) — OPTIONAL
# ============================================
VITE_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# If the frontend is hosted on a DIFFERENT origin than this proxy:
# VITE_API_PROXY=https://wealth-ai-pro.onrender.com

# ============================================
# REAL-TIME MARKET DATA
# ============================================
FINNHUB_API_KEY=your_finnhub_key_here

# ============================================
# BROKER CONNECTORS (Optional — read-only)
# ============================================
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
SHOONYA_USER_ID=your_shoonya_user_id
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_API_KEY=your_api_key
SHOONYA_IMEI=100001
