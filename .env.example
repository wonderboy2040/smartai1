# ============================================
# Deep Mind AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Tavily Search API (Real-time Web Data) - REQUIRED
# Get your key from: https://tavily.com
# ============================================
VITE_TAVILY_API_KEY=tvly-your-api-key-here

# ============================================
# NVIDIA API (DeepSeek V3 for Analysis) - REQUIRED
# Get your key from: https://build.nvidia.com
# ============================================
VITE_NVIDIA_API_KEY=nvapi-your-nvidia-key-here
VITE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
VITE_NVIDIA_MODEL=deepseek-ai/deepseek-r1

# ============================================
# Groq API (Fast Responses) - OPTIONAL
# Get your key from: https://console.groq.com
# ============================================
VITE_GROQ_API_KEY=gsk-your-groq-key-here

# ============================================
# Telegram Bot Configuration - OPTIONAL (for bot.mjs)
# ============================================
VITE_TG_TOKEN=your_bot_token_here
VITE_TG_CHAT_ID=your_chat_id_here

# ============================================
# Google Apps Script (Cloud Sync) - OPTIONAL
# ============================================
VITE_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
